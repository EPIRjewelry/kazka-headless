{
  "name": "epir-headless",
  "private": true,
  "workspaces": ["apps/kazka", "apps/zareczyny", "packages/*"],
  "scripts": {
    "dev:kazka": "npm run dev -w apps/kazka",
    "dev:zareczyny": "npm run dev -w apps/zareczyny",
    "build:kazka": "npm run build -w apps/kazka",
    "build:zareczyny": "npm run build -w apps/zareczyny",
    "deploy:kazka": "npm run deploy -w apps/kazka",
    "deploy:zareczyny": "npm run deploy -w apps/zareczyny",
    "deploy": "npm run deploy:kazka && npm run deploy:zareczyny"
  },
  "engines": {
    "node": ">=18"
  }
}
